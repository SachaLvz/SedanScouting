// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SCOUT
}

model User {
  id           String    @id @default(cuid())
  firstName    String    @default("") @map("prenom")
  lastName     String    @map("nom")
  email        String?   @unique
  role         Role      @default(SCOUT)
  passwordHash String?
  inviteToken  String?
  inviteExpiry DateTime?
  actif        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Player {
  id              String   @id
  firstName       String   @default("") @map("prenom")
  lastName        String   @map("nom")
  dateNaissance   String   @default("")
  ville           String   @default("")
  poste           String   @default("Gardien")
  posteSecondaire String   @default("")
  pied            String   @default("Droitier")
  taille          String   @default("")
  poids           String   @default("")
  photo           String   @default("")
  profilePhoto    String   @default("")
  photos          Json     @default("[]")
  phone           String   @default("")
  nationalite     String   @default("")
  pieceIdentite   String   @default("")
  agent           String   @default("")
  finContrat      String   @default("")
  valeur          String   @default("")
  clubActuel      String   @default("")
  historique      String   @default("")
  rapports        Json     @default("[]")
  notes           Json     @default("[]")
  listes          Json     @default("[]")
  createdAt       String   @default("")
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@map("players")
}

model Match {
  id          String   @id
  date        String   @default("")
  hour        String   @default("")
  equipe1     String   @default("")
  equipe2     String   @default("")
  lieu        String   @default("")
  competition String   @default("")
  type        String   @default("live")
  statut      String   @default("planifie")
  scouts      Json     @default("[]")
  updatedAt   DateTime @updatedAt

  @@map("matches")
}

model ShadowCategory {
  id      String       @id @default(cuid())
  ownerId String       @default("main")
  name    String
  teams   ShadowTeam[]

  @@map("shadow_categories")
}

model ShadowTeam {
  id         String          @id @default(cuid())
  ownerId    String          @default("main")
  name       String          @default("Shadow Team")
  formation  String          @default("4-3-3")
  slots      Json            @default("{}")
  categoryId String?
  category   ShadowCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  updatedAt  DateTime        @updatedAt

  @@map("shadow_team")
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("cities")
}
